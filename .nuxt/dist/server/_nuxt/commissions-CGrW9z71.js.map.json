eString() }}</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({ layout: 'dashboard' })\nconst api = usePartnerDashboardApi()\nconst items = ref<any[]>([]); const loading = ref(true)\nonMounted(async () => { try { const r = await api.getMyCommissions({ limit: 50 }); items.value = (r as any)?.data || [] } catch {} finally { loading.value = false } })\n</script>\n"],"version":3}